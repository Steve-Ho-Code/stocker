# Telegram Bot Configuration
API_TOKEN=""
CHANNEL_ID=""
SUPER_ADMIN_TELEGRAM_ID="" # The Telegram User ID of the account that has ultimate control.

# External Services
FINNHUB_API_KEY=""
ALPHA_VANTAGE_API_KEY=""
ACTIVE_PROVIDER="finnhub" # Choose between 'finnhub' or 'alpha_vantage'

# Infrastructure Configuration
# These values are pre-configured for the docker-compose setup.
DATABASE_URL="postgresql://user:password@db:5432/stocker"
REDIS_URL="redis://redis:6379"

# Schedule Configuration
# Supported frequencies: 1, 5, 10, 15, 30, 60 minutes.
SCHEDULE_FREQUENCY_MINUTES="60"
SCHEDULE_START_TIME="00:00"
SCHEDULE_END_TIME="23:59"
SCHEDULE_TIMEZONE="America/New_York"

# Optional: Logging Configuration
# LOG_LEVEL="INFO" # e.g., DEBUG, INFO, WARNING, ERROR
